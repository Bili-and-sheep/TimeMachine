{% extends 'base.html.twig' %}

{% block title %}Hello GentlePuppyController!{% endblock %}

{% block body %}
<style>
    .example-wrapper { margin: 1em auto; max-width: 800px; width: 95%; font: 18px/1.5 sans-serif; }
    .example-wrapper code { background: #F5F5F5; padding: 2px 6px; }
</style>

<div class="example-wrapper">
    <h1>Hello {{ controller_name }}! ✅</h1>

    This friendly message is coming from:
    <div class="space-x-4">
        <a href="{{ path('app_login') }}" class="text-gray-300 hover:text-white">Login</a>
        <a href="{{ path('app_register') }}" class="text-gray-300 hover:text-white">register</a>
        <a href="{{ path('app_logout') }}" class="text-gray-300 hover:text-white">Logout</a>
        <a href="{{ path('app_user_index') }}" class="text-gray-300 hover:text-white">User</a>
    </div>
</div>
{% endblock %}
