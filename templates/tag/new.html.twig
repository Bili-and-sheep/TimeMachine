{% extends 'base.html.twig' %}
{% block title %}New Tag — Apple Time Machine{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-6 py-12">
    <a href="{{ path('app_tag_index') }}" class="text-sm text-apple-blue hover:underline">← Tags</a>

    <h1 class="text-3xl font-bold tracking-tight text-apple-dark mt-4 mb-8">New tag</h1>

    {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
        <div>
            {{ form_label(form.name, null, {label_attr: {class: 'block text-xs text-apple-gray mb-1'}}) }}
            {{ form_widget(form.name, {attr: {class: 'w-full border border-apple-border rounded-lg px-3 py-2 text-sm text-apple-dark focus:outline-none focus:border-apple-blue transition-colors bg-white', placeholder: 'e.g. portable'}}) }}
            {{ form_errors(form.name) }}
        </div>
        <button type="submit"
                class="px-5 py-2.5 bg-apple-blue text-white text-sm font-medium rounded-full hover:bg-[#0077ed] transition-colors cursor-pointer">
            Create tag
        </button>
    {{ form_end(form) }}
</div>
{% endblock %}