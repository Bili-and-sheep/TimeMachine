{% extends 'base.html.twig' %}
{% block title %}Submit a product — Apple Time Machine{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-6 py-12">
    <h1 class="text-4xl font-bold tracking-tight text-apple-dark mb-2">Submit a product</h1>
    <p class="text-apple-gray mb-8">Your submission will be reviewed before appearing in the archive.</p>

    {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
        {% for field in form %}
            <div>
                {{ form_label(field, null, {label_attr: {class: 'block text-xs text-apple-gray mb-1'}}) }}
                {{ form_widget(field, {attr: {class: 'w-full border border-apple-border rounded-lg px-3 py-2 text-sm text-apple-dark focus:outline-none focus:border-apple-blue transition-colors bg-white'}}) }}
                {{ form_errors(field) }}
            </div>
        {% endfor %}

        <button type="submit"
                class="mt-2 px-5 py-2.5 bg-apple-blue text-white text-sm font-medium rounded-full hover:bg-[#0077ed] transition-colors cursor-pointer">
            Submit for review
        </button>
    {{ form_end(form) }}

    <a href="{{ path('app_home') }}" class="inline-block mt-6 text-sm text-apple-blue hover:underline">← Back to home</a>
</div>
{% endblock %}
