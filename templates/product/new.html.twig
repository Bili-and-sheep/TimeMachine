{% extends 'base.html.twig' %}

{% block title %}Submit a product{% endblock %}

{% block body %}
<div style="padding:16px;">
    <h1>Submit a product</h1>
    <p>Your submission will be reviewed before appearing on the site.</p>

    {{ form_start(form) }}
        {{ form_row(form.ProductName) }}
        {{ form_row(form.TechnicalName) }}
        {{ form_row(form.ProductType) }}
        {{ form_row(form.ReleaseDate) }}
        {{ form_row(form.DiscontinuedYear) }}
        {{ form_row(form.LaunchOS) }}
        {{ form_row(form.LastSupportedOS) }}
        {{ form_row(form.OriginalPrice) }}
        {{ form_row(form.Description) }}
        {{ form_row(form.Sources) }}
        {{ form_row(form.tags) }}

        <button type="submit">Submit for review</button>
    {{ form_end(form) }}

    <p><a href="{{ path('app_home') }}">← Back to home</a></p>
</div>
{% endblock %}
