{% extends 'base.html.twig' %}
{% block title %}{{ product.productName }} — Apple Time Machine{% endblock %}

{# ─── Color name → hex map for Apple palette ─── #}
{% set colorMap = {
    'space gray': '#535150', 'space grey': '#535150',
    'silver': '#e3e4e5', 'gold': '#f0dfc0', 'rose gold': '#e8c6b5',
    'midnight': '#1f2b35', 'starlight': '#f0ede8',
    'black': '#1d1d1f', 'white': '#f5f5f7',
    'product red': '#c62828', 'red': '#c62828',
    'blue': '#3478c8', 'green': '#41a05b', 'yellow': '#f5e142',
    'purple': '#7e4d8b', 'coral': '#e97462', 'pink': '#f4a7b2',
    'midnight green': '#4c5b52', 'pacific blue': '#3c7fb8',
    'sierra blue': '#6ea5c8', 'alpine green': '#556755',
    'deep purple': '#4e3a6e', 'natural titanium': '#d5cec6',
    'black titanium': '#3a3a3a', 'white titanium': '#e8e6e3',
    'desert titanium': '#c5a97e', 'ultramarine': '#3c4e9e',
    'teal': '#2e7d7e', 'orange': '#e07a35', 'slate': '#5a6877',
    'dark cherry': '#5b1a2a',
} %}

{% block body %}

{# ══════════════════════════════════════════════════
   SECTION 1 — HERO (Apple "buy page" layout)
   Title block on top, then 2-column split:
   image on the left, configurator cards on the right.
   ══════════════════════════════════════════════════ #}
<section class="bg-[#f5f5f7]">
    <div class="max-w-[1024px] mx-auto px-6 pt-12 pb-6">

        {# ── Title row ── #}
        <h1 class="text-[40px] md:text-[56px] font-bold tracking-tight leading-[1.05] text-apple-dark">
            Découvrir le {{ product.productName }}
        </h1>

        {% if product.originalPrice %}
            <p class="mt-3 text-base md:text-lg text-apple-dark">
                À partir de <span class="font-medium">${{ product.originalPrice }}</span>
                {% if product.inflationAdjustedPrice %}
                    <span class="text-apple-gray"> ou ${{ product.inflationAdjustedPrice }} ajusté à l'inflation<sup>°°</sup></span>
                {% endif %}
            </p>
        {% endif %}

        {# ── Tagline / technical name + meta badges ── #}
        <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2">
            {% if product.technicalName and product.technicalName != product.productName %}
                <p class="inline-flex items-center gap-2 text-sm font-medium text-apple-dark">
                    <span class="inline-block w-4 h-4 rounded-full bg-gradient-to-tr from-pink-400 via-amber-400 to-sky-400"></span>
                    {{ product.technicalName }}
                    <span class="text-apple-blue text-xs hover:underline cursor-pointer">En savoir plus ⊕</span>
                </p>
            {% endif %}

            {# Energy-label-style "A" badge → uses category #}
            <span class="inline-flex items-center gap-1.5 bg-green-600 text-white text-[11px] font-bold px-2.5 py-0.5 rounded-sm">
                A
                <span class="font-normal text-[10px] opacity-80">{{ product.productType.type }}</span>
            </span>
        </div>
    </div>

    {# ── Main 2-column split ── #}
    <div class="max-w-[1024px] mx-auto px-6 pb-16">
        <div class="bg-white rounded-3xl border border-apple-border overflow-hidden">
            <div class="grid grid-cols-1 lg:grid-cols-[1.4fr_1fr] gap-0">

                {# ── LEFT : hero image ── #}
                <div class="relative bg-[#f5f5f7] flex items-center justify-center px-6 py-12 lg:py-16 min-h-[420px]">
                    {% if product.images is not empty %}
                        <img src="{{ product.images.first.path }}"
                             alt="{{ product.productName }}"
                             class="max-w-full max-h-[440px] object-contain">
                    {% else %}
                        <div class="w-48 h-48 bg-apple-border/40 rounded-3xl flex items-center justify-center text-apple-gray text-sm">
                            No image
                        </div>
                    {% endif %}

                    {# Discontinued + release pill, top-left of image #}
                    <div class="absolute top-5 left-5 flex items-center gap-2">
                        <span class="inline-flex items-center gap-1.5 bg-apple-dark text-white text-[11px] font-semibold px-2.5 py-1 rounded-full">
                            <span class="w-1.5 h-1.5 rounded-full bg-red-400"></span>
                            Discontinued
                            {% if product.discontinuedYear %} {{ product.discontinuedYear|date('Y') }}{% endif %}
                        </span>
                        {% if product.releaseDate %}
                            <span class="text-[11px] text-apple-gray bg-white/70 backdrop-blur px-2 py-1 rounded-full">
                                Released {{ product.releaseDate|date('Y') }}
                            </span>
                        {% endif %}
                    </div>

                    {# Right-edge chevron, like Apple's gallery navigator #}
                    {% if product.images|length > 1 %}
                        <button type="button"
                                class="hidden lg:flex absolute right-4 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-white shadow-md items-center justify-center text-apple-dark hover:scale-105 transition-transform"
                                aria-label="Next image">›</button>
                    {% endif %}
                </div>

                {# ── RIGHT : configurator cards ── #}
                <div class="px-6 lg:px-8 py-8 lg:py-12 flex flex-col gap-6">

                    {% if product.options %}
                        {% for optionKey, optionValues in product.options %}
                            {% set isColor = 'color' in optionKey|lower %}

                            <div>
                                <h2 class="text-base md:text-lg font-semibold tracking-tight text-apple-dark mb-3">
                                    <span class="text-apple-dark">{{ optionKey|capitalize }}.</span>
                                    <span class="text-apple-gray font-normal">
                                        {% if isColor %}Quelle couleur préférez-vous ?
                                        {% elseif 'storage' in optionKey|lower %}Quelle capacité vous faut-il ?
                                        {% elseif 'size' in optionKey|lower %}Quelle taille vous faut-il ?
                                        {% else %}Quelle option vous faut-il ?{% endif %}
                                    </span>
                                </h2>

                                {# Color → swatch cards #}
                                {% if isColor and optionValues is iterable %}
                                    <div class="flex flex-wrap gap-3">
                                        {% for color in optionValues %}
                                            {% set colorKey = color|lower %}
                                            {% set hex = colorMap[colorKey] ?? '#d2d2d7' %}
                                            <button type="button"
                                                    class="group flex items-center gap-2 border border-apple-border hover:border-apple-dark rounded-xl px-3 py-2 transition-colors">
                                                <span class="w-5 h-5 rounded-full ring-1 ring-apple-border"
                                                      style="background-color: {{ hex }}"></span>
                                                <span class="text-xs text-apple-dark">{{ color }}</span>
                                            </button>
                                        {% endfor %}
                                    </div>

                                {# Other options → "model picker" cards (left label, right price) #}
                                {% elseif optionValues is iterable %}
                                    <div class="flex flex-col gap-2">
                                        {% for value in optionValues %}
                                            <button type="button"
                                                    class="text-left border border-apple-border hover:border-apple-dark rounded-2xl px-4 py-3 flex items-start justify-between gap-4 transition-colors">
                                                <div>
                                                    <p class="text-sm font-semibold text-apple-dark leading-tight">
                                                        {{ product.productName }}
                                                    </p>
                                                    <p class="text-[11px] text-apple-gray mt-0.5">{{ value }}</p>
                                                </div>
                                                {% if product.originalPrice %}
                                                    <div class="text-right shrink-0">
                                                        <p class="text-[11px] text-apple-gray leading-tight">À partir de</p>
                                                        <p class="text-sm font-semibold text-apple-dark">${{ product.originalPrice }}</p>
                                                        {% if product.inflationAdjustedPrice %}
                                                            <p class="text-[10px] text-apple-gray">
                                                                ou ${{ product.inflationAdjustedPrice }} aujourd'hui<sup>°°</sup>
                                                            </p>
                                                        {% endif %}
                                                    </div>
                                                {% endif %}
                                            </button>
                                        {% endfor %}
                                    </div>

                                {% else %}
                                    <p class="text-sm text-apple-dark">{{ optionValues }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    {% else %}
                        {# No options? Show one "model card" + tech intro #}
                        <div>
                            <h2 class="text-base md:text-lg font-semibold tracking-tight text-apple-dark mb-3">
                                <span>Modèle.</span>
                                <span class="text-apple-gray font-normal">Quel modèle vous faut-il ?</span>
                            </h2>
                            <div class="border border-apple-dark rounded-2xl px-4 py-3 flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-sm font-semibold text-apple-dark leading-tight">
                                        {{ product.productName }}
                                    </p>
                                    {% if product.technicalName %}
                                        <p class="text-[11px] text-apple-gray mt-0.5">{{ product.technicalName }}</p>
                                    {% endif %}
                                </div>
                                {% if product.originalPrice %}
                                    <div class="text-right shrink-0">
                                        <p class="text-[11px] text-apple-gray leading-tight">À partir de</p>
                                        <p class="text-sm font-semibold text-apple-dark">${{ product.originalPrice }}</p>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    {# "Besoin d'aide" expandable row #}
                    <div class="mt-auto pt-6 border-t border-apple-border">
                        <button type="button"
                                class="w-full flex items-start justify-between gap-3 text-left group">
                            <div>
                                <p class="text-sm font-semibold text-apple-dark group-hover:underline">
                                    Besoin d'aide pour explorer cet appareil&nbsp;?
                                </p>
                                <p class="text-xs text-apple-gray mt-0.5">
                                    Découvrez les caractéristiques techniques et l'historique du produit.
                                </p>
                            </div>
                            <span class="text-apple-blue text-lg leading-none mt-0.5">⊕</span>
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>

{# ══════════════════════════════════════════════════
   SECTION 3 — OS SUPPORT TIMELINE
   ══════════════════════════════════════════════════ #}
{% if product.launchOS or product.lastSupportedOS %}
<section class="border-t border-apple-border bg-[#f5f5f7] py-14">
    <div class="max-w-[680px] mx-auto px-6">
        <h2 class="text-xs uppercase tracking-widest text-apple-gray font-medium mb-6">Software support</h2>

        <div class="flex items-center gap-4 flex-wrap">
            {% if product.launchOS %}
                <div class="text-center">
                    <p class="text-[10px] uppercase tracking-widest text-apple-gray mb-1">Launched with</p>
                    <span class="inline-block bg-apple-dark text-white text-sm font-medium px-4 py-1.5 rounded-full">
                        {{ product.launchOS }}
                    </span>
                </div>
            {% endif %}

            {% if product.launchOS and product.lastSupportedOS %}
                <div class="flex-1 min-w-[60px]">
                    <div class="h-px bg-gradient-to-r from-apple-dark to-apple-gray relative">
                        <span class="absolute right-0 top-1/2 -translate-y-1/2 text-apple-gray text-xs">›</span>
                    </div>
                </div>
            {% endif %}

            {% if product.lastSupportedOS %}
                <div class="text-center">
                    <p class="text-[10px] uppercase tracking-widest text-apple-gray mb-1">Last supported</p>
                    <span class="inline-block bg-apple-gray text-white text-sm font-medium px-4 py-1.5 rounded-full">
                        {{ product.lastSupportedOS }}
                    </span>
                </div>
            {% endif %}
        </div>
    </div>
</section>
{% endif %}

{# ══════════════════════════════════════════════════
   SECTION 4 — TECH SPECS
   ══════════════════════════════════════════════════ #}
<section class="border-t border-apple-border bg-white py-14">
    <div class="max-w-[680px] mx-auto px-6">
        <h2 class="text-3xl font-bold tracking-tight text-apple-dark mb-8">Tech Specs</h2>

        <dl class="divide-y divide-apple-border">
            {% set specs = [
                ['Category',          product.productType.type],
                ['Release date',      product.releaseDate ? product.releaseDate|date('F j, Y') : null],
                ['Year discontinued', product.discontinuedYear ? product.discontinuedYear|date('Y') : null],
                ['Launch OS',         product.launchOS ?? null],
                ['Last supported OS', product.lastSupportedOS ?? null],
                ['Original price',    product.originalPrice ? '$' ~ product.originalPrice : null],
                ['Inflation-adjusted','$' ~ (product.inflationAdjustedPrice ?? '—') ~ ' (today)'],
            ] %}
            {% for spec in specs %}
                {% if spec[1] %}
                    <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-6">
                        <dt class="text-sm font-medium text-apple-gray">{{ spec[0] }}</dt>
                        <dd class="mt-1 sm:mt-0 sm:col-span-2 text-sm text-apple-dark">{{ spec[1] }}</dd>
                    </div>
                {% endif %}
            {% endfor %}

            {% if product.description %}
                <div class="py-4 sm:grid sm:grid-cols-3 sm:gap-6">
                    <dt class="text-sm font-medium text-apple-gray">Description</dt>
                    <dd class="mt-1 sm:mt-0 sm:col-span-2 text-sm text-apple-dark leading-relaxed">
                        {{ product.description }}
                    </dd>
                </div>
            {% endif %}
        </dl>
    </div>
</section>

{# ══════════════════════════════════════════════════
   SECTION 5 — TAGS
   ══════════════════════════════════════════════════ #}
{% if product.tags is not empty %}
<section class="border-t border-apple-border bg-[#f5f5f7] py-12">
    <div class="max-w-[680px] mx-auto px-6">
        <h2 class="text-xs uppercase tracking-widest text-apple-gray font-medium mb-4">Archive tags</h2>
        <div class="flex flex-wrap gap-2">
            {% for tag in product.tags %}
                <span class="px-3 py-1 bg-white border border-apple-border text-apple-dark text-xs rounded-full font-medium">
                    {{ tag.name }}
                </span>
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ══════════════════════════════════════════════════
   SECTION 6 — SOURCES
   ══════════════════════════════════════════════════ #}
{% if product.sources %}
<section class="border-t border-apple-border bg-white py-12">
    <div class="max-w-[680px] mx-auto px-6">
        <h2 class="text-xs uppercase tracking-widest text-apple-gray font-medium mb-3">Sources</h2>
        <p class="text-sm text-apple-gray leading-relaxed">{{ product.sources }}</p>
    </div>
</section>
{% endif %}

{# ══════════════════════════════════════════════════
   SECTION 7 — ADDITIONAL IMAGES
   ══════════════════════════════════════════════════ #}
{% if product.images|length > 1 %}
<section class="border-t border-apple-border bg-[#f5f5f7] py-12">
    <div class="max-w-[980px] mx-auto px-6">
        <h2 class="text-xs uppercase tracking-widest text-apple-gray font-medium mb-6">Gallery</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
            {% for image in product.images %}
                <img src="{{ image.path }}" alt="{{ product.productName }}"
                     class="w-full aspect-square object-contain bg-white rounded-2xl p-4">
            {% endfor %}
        </div>
    </div>
</section>
{% endif %}

{# ══════════════════════════════════════════════════
   STICKY FOOTER — navigation + barista actions
   ══════════════════════════════════════════════════ #}
<div class="sticky bottom-0 z-40 bg-white/80 backdrop-blur-xl border-t border-apple-border">
    <div class="max-w-[980px] mx-auto px-6 py-3 flex items-center justify-between gap-4 flex-wrap">
        <div class="flex items-center gap-1 min-w-0">
            <span class="text-sm font-semibold text-apple-dark truncate">{{ product.productName }}</span>
            {% if product.originalPrice %}
                <span class="text-apple-gray text-sm hidden sm:inline">&nbsp;·&nbsp; ${{ product.originalPrice }}</span>
            {% endif %}
        </div>

        <div class="flex items-center gap-3 flex-wrap shrink-0">
            <a href="{{ app.request.headers.get('referer') ?: path('app_home') }}"
               class="text-apple-blue text-sm hover:underline">← Back</a>

            {% if is_granted('ROLE_BARISTA') %}
                <a href="{{ path('app_product_edit', {id: product.id}) }}"
                   class="px-4 py-1.5 text-sm border border-apple-blue text-apple-blue rounded-full hover:bg-apple-blue hover:text-white transition-all">
                    Edit
                </a>
                <a href="{{ path('app_product_history', {id: product.id}) }}"
                   class="px-4 py-1.5 text-sm border border-apple-border text-apple-gray rounded-full hover:border-apple-dark hover:text-apple-dark transition-all">
                    History
                </a>
                <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}"
                      onsubmit="return confirm('Delete « {{ product.productName }} »? This cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                    <button type="submit"
                            class="px-4 py-1.5 text-sm border border-red-300 text-red-500 rounded-full hover:bg-red-500 hover:text-white transition-all cursor-pointer">
                        Delete
                    </button>
                </form>
            {% endif %}
        </div>
    </div>
</div>

{% endblock %}
