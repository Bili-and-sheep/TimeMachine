{% extends 'base.html.twig' %}

{% block title %}{{ product.productName }} — Apple Time Machine{% endblock %}

{% block body %}
<div class="content-page">
    <p style="font-size:12px; color:#6e6e73; text-transform:uppercase; letter-spacing:.06em; margin-bottom:8px;">
        {{ product.productType.type }}
    </p>
    <h1>{{ product.productName }}</h1>
    <p style="color:#6e6e73; font-size:15px; margin-top:4px;">{{ product.technicalName }}</p>

    {% if product.images is not empty %}
        <img src="{{ product.images.first.path }}" alt="{{ product.productName }}"
             style="max-width:360px; width:100%; display:block; margin:32px auto; border-radius:12px;">
    {% endif %}

    <table>
        <tr><th>Release date</th><td>{{ product.releaseDate ? product.releaseDate|date('Y-m-d') : '—' }}</td></tr>
        <tr><th>Year discontinued</th><td>{{ product.discontinuedYear ? product.discontinuedYear|date('Y') : '—' }}</td></tr>
        <tr><th>Launch OS</th><td>{{ product.launchOS ?? '—' }}</td></tr>
        <tr><th>Last supported OS</th><td>{{ product.lastSupportedOS ?? '—' }}</td></tr>
        <tr><th>Original price</th><td>{% if product.originalPrice %}${{ product.originalPrice }}{% else %}—{% endif %}</td></tr>
        <tr>
            <th>Inflation-adjusted</th>
            <td>{{ product.inflationAdjustedPrice ? '$' ~ product.inflationAdjustedPrice : '—' }}</td>
        </tr>
        <tr><th>Description</th><td>{{ product.description ?? '—' }}</td></tr>
        <tr><th>Sources</th><td>{{ product.sources ?? '—' }}</td></tr>
        <tr>
            <th>Tags</th>
            <td>{{ product.tags is not empty ? product.tags|map(t => t.name)|join(', ') : '—' }}</td>
        </tr>
    </table>

    <a class="back-link" href="{{ app.request.headers.get('referer') ?: path('app_home') }}">← Back</a>

    {% if is_granted('ROLE_BARISTA') %}
        <div class="action-bar">
            <a class="btn btn-secondary" href="{{ path('app_product_edit', {id: product.id}) }}">Edit</a>
            <a class="btn btn-secondary" href="{{ path('app_product_history', {id: product.id}) }}">History</a>
            <form method="post" action="{{ path('app_product_delete', {id: product.id}) }}"
                  onsubmit="return confirm('Delete « {{ product.productName }} »? This cannot be undone.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                <button class="btn btn-danger" type="submit">Delete</button>
            </form>
        </div>
    {% endif %}
</div>
{% endblock %}
