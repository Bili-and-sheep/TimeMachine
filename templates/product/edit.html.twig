{% extends 'base.html.twig' %}
{% block title %}Edit — {{ product.productName }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-6 py-12">
    <p class="text-[10px] text-apple-gray uppercase tracking-widest mb-1">{{ product.productType.type }}</p>
    <h1 class="text-4xl font-bold tracking-tight text-apple-dark mb-1">{{ product.productName }}</h1>
    <p class="text-sm text-apple-gray mb-8">Status: <span class="font-medium">{{ product.status.label() }}</span></p>

    {% if product.images is not empty %}
    <div class="mb-6">
        <span class="block text-xs text-apple-gray mb-2">Current images</span>
        <div class="grid grid-cols-3 gap-3">
            {% for image in product.images %}
            <div class="relative group">
                <img src="{{ image.path }}" alt="{{ product.productName }}"
                     class="w-full aspect-square object-contain bg-[#f5f5f7] rounded-xl p-2">
                <form method="post"
                      action="{{ path('app_product_image_delete', {id: product.id, imageId: image.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_image_' ~ image.id) }}">
                    <button type="submit"
                            class="absolute top-1.5 right-1.5 w-6 h-6 bg-red-500 hover:bg-red-600 text-white rounded-full text-sm leading-none flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer"
                            title="Remove image">×</button>
                </form>
            </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
        {% for field in form %}
            <div>
                {{ form_label(field, null, {label_attr: {class: 'block text-xs text-apple-gray mb-1'}}) }}
                {% if field.vars.name == 'imageFiles' %}
                    {{ form_widget(field, {attr: {class: 'w-full text-sm text-apple-dark', multiple: true}}) }}
                {% else %}
                    {{ form_widget(field, {attr: {class: 'w-full border border-apple-border rounded-lg px-3 py-2 text-sm text-apple-dark focus:outline-none focus:border-apple-blue transition-colors bg-white'}}) }}
                {% endif %}
                {{ form_errors(field) }}
            </div>
        {% endfor %}

        <button type="submit"
                class="mt-2 px-5 py-2.5 bg-apple-blue text-white text-sm font-medium rounded-full hover:bg-[#0077ed] transition-colors cursor-pointer">
            Save changes
        </button>
    {{ form_end(form) }}

    <a href="{{ path('app_product_show', {id: product.id}) }}" class="inline-block mt-6 text-sm text-apple-blue hover:underline">← Cancel</a>
</div>
{% endblock %}
