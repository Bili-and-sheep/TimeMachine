{% extends 'base.html.twig' %}
{% block title %}Apple Time Machine{% endblock %}

{% block body %}
{% if product %}
    <section class="text-center py-20 px-6 bg-white">
        <p class="text-sm text-apple-gray uppercase tracking-widest mb-2">{{ product.productType.type }}</p>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-apple-dark leading-[1.05] mb-3">
            {{ product.productName }}
        </h1>
        {% if product.description %}
            <p class="text-lg text-apple-gray max-w-xl mx-auto mb-2 leading-relaxed">
                {{ product.description|slice(0, 120) }}{% if product.description|length > 120 %}…{% endif %}
            </p>
        {% endif %}
        {% if product.releaseDate %}
            <p class="text-sm text-apple-gray mb-6">
                {{ product.releaseDate|date('Y') }}{% if product.discontinuedYear %} — {{ product.discontinuedYear|date('Y') }}{% endif %}
            </p>
        {% endif %}
        <div class="flex gap-6 justify-center items-center">
            <a href="{{ path('app_product_show', {id: product.id}) }}"
               class="text-apple-blue text-base hover:underline">View archive entry ›</a>
            <a href="{{ path('app_browse', {category: 'iphone'}) }}"
               class="text-apple-gray text-sm hover:underline">Browse all ›</a>
        </div>
        {% if product.images is not empty %}
            <img src="{{ product.images.first.path }}" alt="{{ product.productName }}"
                 class="max-w-sm w-full mx-auto mt-10 rounded-2xl block">
        {% endif %}
    </section>
{% else %}
    <div class="text-center py-32 px-6 text-apple-gray">
        <p class="text-lg">The archive is empty for now.</p>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_product_new') }}" class="inline-block mt-4 text-apple-blue hover:underline">
                Be the first to submit a product ›
            </a>
        {% else %}
            <a href="{{ path('app_register') }}" class="inline-block mt-4 text-apple-blue hover:underline">
                Create an account to contribute ›
            </a>
        {% endif %}
    </div>
{% endif %}
{% endblock %}
