{% extends 'base.html.twig' %}
{% block title %}User — Apple Time Machine{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-6 py-12">
    <a href="{{ path('app_user_index') }}" class="text-sm text-apple-blue hover:underline">← Users</a>

    <h1 class="text-3xl font-bold tracking-tight text-apple-dark mt-4 mb-8">User</h1>

    <div class="divide-y divide-apple-border border border-apple-border rounded-2xl overflow-hidden mb-6">
        <div class="px-5 py-3.5 bg-white">
            <p class="text-xs text-apple-gray mb-0.5">ID</p>
            <p class="text-sm text-apple-dark">{{ user.id }}</p>
        </div>
        <div class="px-5 py-3.5 bg-white">
            <p class="text-xs text-apple-gray mb-0.5">UUID</p>
            <p class="text-sm text-apple-dark font-mono">{{ user.uuid }}</p>
        </div>
        <div class="px-5 py-3.5 bg-white">
            <p class="text-xs text-apple-gray mb-1.5">Roles</p>
            <div class="flex flex-wrap gap-1.5">
                {% for role in user.roles %}
                    <span class="px-2 py-0.5 text-[10px] font-medium rounded-full border
                        {{ role == 'ROLE_ADMIN'    ? 'bg-red-50 border-red-200 text-red-600' :
                           role == 'ROLE_BARISTA'  ? 'bg-purple-50 border-purple-200 text-purple-600' :
                           role == 'ROLE_REVIEWER' ? 'bg-blue-50 border-blue-200 text-blue-600' :
                           'bg-apple-light border-apple-border text-apple-gray' }}">
                        {{ role|replace({'ROLE_': ''}) }}
                    </span>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="flex items-center gap-4">
        <a href="{{ path('app_user_edit', {id: user.id}) }}"
           class="px-5 py-2.5 bg-apple-blue text-white text-sm font-medium rounded-full hover:bg-[#0077ed] transition-colors">
            Edit
        </a>
        <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}"
              onsubmit="return confirm('Delete user {{ user.uuid }}?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
            <button type="submit"
                    class="px-5 py-2.5 text-sm font-medium rounded-full border border-red-300 text-red-500 hover:bg-red-500 hover:text-white transition-all cursor-pointer">
                Delete
            </button>
        </form>
    </div>
</div>
{% endblock %}