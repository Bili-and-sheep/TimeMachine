{% extends 'base.html.twig' %}

{% block title %}Edit User #{{ user.id }}{% endblock %}

{% block body %}
<div class="max-w-[640px] mx-auto px-5 py-12">
    <div class="mb-8">
        <a href="{{ path('app_user_index') }}"
           class="text-xs text-apple-gray hover:text-apple-dark transition-colors">← Back to users</a>
        <h1 class="text-3xl font-semibold text-apple-dark mt-3">Edit User #{{ user.id }}</h1>
    </div>

    <div class="border border-apple-border rounded-xl p-6 bg-white mb-6">
        {{ include('user/_form.html.twig', {'button_label': 'Update'}) }}
    </div>

    <div class="flex justify-end">
        {{ include('user/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
