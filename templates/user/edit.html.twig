{% extends 'base.html.twig' %}
{% block title %}Edit User — Apple Time Machine{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-6 py-12">
    <a href="{{ path('app_user_index') }}" class="text-sm text-apple-blue hover:underline">← Users</a>

    <h1 class="text-3xl font-bold tracking-tight text-apple-dark mt-4 mb-1">Edit user</h1>
    <p class="text-xs text-apple-gray font-mono mb-8">{{ user.uuid }}</p>

    {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
        <div>
            <span class="block text-xs text-apple-gray mb-2">Roles</span>
            <div class="flex flex-wrap gap-2">
                {% for choice in form.roles %}
                    <label class="cursor-pointer inline-flex items-center px-3 py-1.5 text-xs font-medium rounded-full border border-apple-border text-apple-dark bg-white has-[:checked]:bg-apple-dark has-[:checked]:text-white has-[:checked]:border-apple-dark transition-colors select-none">
                        {{ form_widget(choice, {attr: {class: 'sr-only'}}) }}
                        {{ choice.vars.label }}
                    </label>
                {% endfor %}
            </div>
            {{ form_errors(form.roles) }}
        </div>
        <div class="flex items-center gap-4">
            <button type="submit"
                    class="px-5 py-2.5 bg-apple-blue text-white text-sm font-medium rounded-full hover:bg-[#0077ed] transition-colors cursor-pointer">
                Save changes
            </button>
            <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}"
                  onsubmit="return confirm('Delete user {{ user.uuid }}?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                <button type="submit"
                        class="px-5 py-2.5 text-sm font-medium rounded-full border border-red-300 text-red-500 hover:bg-red-500 hover:text-white transition-all cursor-pointer">
                    Delete
                </button>
            </form>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}