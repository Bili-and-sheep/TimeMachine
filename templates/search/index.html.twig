{% extends 'base.html.twig' %}
{% block title %}{% if query %}{{ query }} — {% endif %}Search — Apple Time Machine{% endblock %}

{% block body %}
<div class="max-w-[1024px] mx-auto px-6 py-12">

    {# ── Search form ── #}
    <form method="get" action="{{ path('app_search') }}" class="mb-10">
        <div class="flex items-center gap-3 max-w-xl mx-auto">
            <input
                type="search"
                name="q"
                value="{{ query }}"
                placeholder="Search products…"
                autofocus
                class="flex-1 border border-apple-border rounded-full px-5 py-2.5 text-sm text-apple-dark placeholder:text-apple-gray focus:outline-none focus:border-apple-blue transition-colors"
            >
            <button type="submit"
                    class="px-5 py-2.5 bg-apple-blue text-white text-sm font-medium rounded-full hover:bg-[#0077ed] transition-colors cursor-pointer">
                Search
            </button>
        </div>
    </form>

    {# ── Results ── #}
    {% if query is empty %}
        <p class="text-center text-apple-gray text-sm">Enter a product name, category, or year to search the archive.</p>

    {% elseif products is empty %}
        <div class="text-center py-16">
            <p class="text-apple-gray text-sm mb-1">No results for</p>
            <p class="text-apple-dark font-semibold text-lg">"{{ query }}"</p>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_product_new') }}" class="inline-block mt-4 text-apple-blue text-sm hover:underline">
                    Submit it to the archive ›
                </a>
            {% endif %}
        </div>

    {% else %}
        <p class="text-xs text-apple-gray mb-6 text-center">
            {{ products|length }} result{{ products|length > 1 ? 's' : '' }} for "<span class="text-apple-dark">{{ query }}</span>"
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-apple-border">
            {% for product in products %}
                {% include 'product/_product_card.html.twig' %}
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
