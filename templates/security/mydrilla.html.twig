{% extends 'base.html.twig' %}

{% block title %}My Account — Apple Time Machine{% endblock %}

{% block body %}
<div class="max-w-[680px] mx-auto px-6 py-14">

    {# ── Account info ── #}
    <div class="mb-10">
        <h1 class="text-3xl font-bold tracking-tight text-apple-dark mb-1">My Account</h1>
        <p class="text-sm text-apple-gray">
            Roles:
            {% for role in app.user.roles %}
                <span class="font-medium text-apple-dark">{{ role }}</span>{% if not loop.last %}, {% endif %}
            {% endfor %}
        </p>
    </div>

    {# ── Submissions ── #}
    <section class="mb-10">
        <h2 class="text-xs uppercase tracking-widest text-apple-gray font-medium mb-5">My submissions</h2>

        {% set products = app.user.products %}
        {% if products is empty %}
            <p class="text-sm text-apple-gray">You haven't submitted any product yet.
                <a href="{{ path('app_product_new') }}" class="text-apple-blue hover:underline">Submit one ›</a>
            </p>
        {% else %}
            <div class="divide-y divide-apple-border border border-apple-border rounded-2xl overflow-hidden">
                {% for product in products %}
                    {% set s = product.status %}
                    {% set isRejected  = s.value in ['rejected', 'rejected_by_review', 'needs_changes'] %}
                    {% set isApproved  = s.value == 'approved' %}
                    {% set isPending   = s.value in ['pending', 'approved_by_review'] %}

                    <div class="px-5 py-4 bg-white flex items-start justify-between gap-4 flex-wrap">
                        <div class="min-w-0">
                            <p class="text-sm font-semibold text-apple-dark leading-tight truncate">
                                {{ product.productName }}
                            </p>
                            {% if product.rejectionComment and isRejected %}
                                <p class="mt-1 text-xs text-red-500 leading-snug">
                                    ↳ {{ product.rejectionComment }}
                                </p>
                            {% endif %}
                        </div>

                        <span class="shrink-0 text-xs font-medium px-2.5 py-1 rounded-full
                            {% if isApproved %}bg-green-100 text-green-700
                            {% elseif isRejected %}bg-red-100 text-red-600
                            {% else %}bg-amber-100 text-amber-700{% endif %}">
                            {{ s.label() }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </section>

    {# ── Logout ── #}
    <a href="{{ path('app_logout') }}"
       class="inline-block text-sm text-red-500 hover:underline">
        Sign out
    </a>

</div>
{% endblock %}