<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Apple Time Machine{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221em%22 font-size=%22112%22>🍎</text></svg>">

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body class="bg-white text-apple-dark antialiased">

{# ── Global top bar ── #}
<header class="sticky top-0 z-50 h-11 bg-[rgba(29,29,31,0.92)] backdrop-blur-xl">
    <div class="max-w-[1024px] mx-auto px-4 h-full flex items-center justify-between">
        <a href="{{ path('app_home') }}"
           class="text-white/85 hover:text-white transition-opacity text-xl leading-none"
           title="Apple Time Machine">&#63743;</a>

        <div class="max-w-[1024px] mx-auto px-4 flex items-center justify-center">
            {% set navItems = {
                'iphone':      'iPhone',
                'mac':         'Mac',
                'ipad':        'iPad',
                'watch':       'Watch',
                'tv':          'TV',
                'accessories': 'Accessories',
                'other':       'Other'
            } %}
            {% for slug, label in navItems %}
                <a href="{{ path('app_browse', {category: slug}) }}"
                   class="text-white/75 hover:text-white text-xs px-3.5 py-2.5 transition-colors whitespace-nowrap">
                    {{ label }}
                </a>
            {% endfor %}
        </div>

        <div class="flex items-center gap-5">
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_product_new') }}"
                   class="text-white/80 hover:text-white text-xs border border-white/30 hover:border-white/60 rounded-full px-3 py-1 transition-all">
                    + Submit
                </a>
            {% endif %}

            {% if is_granted('ROLE_REVIEWER') %}
                <a href="{{ path('app_review_index') }}"
                   class="relative text-white/80 hover:text-white transition-colors text-base leading-none">
                    🔔
                    {% if pending_count > 0 %}
                        <span class="absolute -top-1.5 -right-2 bg-red-500 text-white text-[9px] font-bold rounded-full px-1 leading-4">
                            {{ pending_count }}
                        </span>
                    {% endif %}
                </a>
            {% endif %}

            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_mydrilla') }}" class="text-white/80 hover:text-white text-xs transition-colors">Account</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="text-white/80 hover:text-white text-xs transition-colors">Sign in</a>
                <a href="{{ path('app_register') }}" class="text-white/80 hover:text-white text-xs transition-colors">Create account</a>
            {% endif %}
        </div>
    </div>
</header>


{# ── Flash messages ── #}
{% for type, messages in app.flashes %}
    {% for message in messages %}
        <div class="px-5 py-2.5 text-sm text-center {{ type == 'error' ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700' }}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ── Main content ── #}
<main class="min-h-[calc(100vh-44px-86px-120px)]">
    {% block body %}{% endblock %}
</main>

{# ── Footer ── #}
<footer class="bg-apple-light border-t border-apple-border text-apple-gray text-xs">
    <div class="max-w-[1024px] mx-auto px-5 py-8">
        <p class="pb-4 mb-4 border-b border-apple-border">
            Apple Time Machine — rediscovering the products that defined an era.
        </p>
        <div class="flex flex-wrap gap-x-5 gap-y-2">
            <a href="{{ path('app_home') }}" class="hover:text-apple-dark transition-colors">Home</a>
            {% for slug, label in navItems %}
                <a href="{{ path('app_browse', {category: slug}) }}" class="hover:text-apple-dark transition-colors">{{ label }}</a>
            {% endfor %}
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_product_new') }}" class="hover:text-apple-dark transition-colors">Submit a product</a>
            {% else %}
                <a href="{{ path('app_register') }}" class="hover:text-apple-dark transition-colors">Create account</a>
            {% endif %}
        </div>
        <p class="mt-4 text-apple-gray">
            Copyright &copy; {{ "now"|date("Y") }} Apple Time Machine. Not affiliated with Apple&nbsp;Inc.
        </p>
    </div>
</footer>

</body>
</html>
