<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Apple Time Machine{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221em%22 font-size=%22112%22>🍎</text></svg>">

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
            background: #fff;
            color: #1d1d1f;
            font-size: 14px;
            line-height: 1.5;
        }

        a { color: inherit; text-decoration: none; }

        /* ── Global nav (top bar) ── */
        .global-nav {
            background: rgba(29,29,31,.9);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            height: 44px;
            position: sticky;
            top: 0;
            z-index: 9999;
        }
        .global-nav__inner {
            max-width: 1024px;
            margin: 0 auto;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
        }
        .global-nav__logo {
            color: #f5f5f7;
            font-size: 20px;
            line-height: 1;
            opacity: .85;
            transition: opacity .2s;
        }
        .global-nav__logo:hover { opacity: 1; }

        /* ── Category nav ── */
        .store-nav {
            background: rgba(29,29,31,.72);
            backdrop-filter: saturate(180%) blur(20px);
            -webkit-backdrop-filter: saturate(180%) blur(20px);
            border-bottom: 1px solid rgba(255,255,255,.08);
        }
        .store-nav__inner {
            max-width: 1024px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0;
            padding: 0 16px;
        }
        .store-nav__item {
            color: rgba(245,245,247,.8);
            font-size: 12px;
            letter-spacing: -.01em;
            padding: 10px 14px;
            display: block;
            transition: color .2s;
            white-space: nowrap;
        }
        .store-nav__item:hover { color: #f5f5f7; }
        .store-nav__item.active { color: #f5f5f7; }

        /* ── Right-side nav controls ── */
        .global-nav__controls {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .global-nav__controls a {
            color: rgba(245,245,247,.8);
            font-size: 12px;
            transition: color .2s;
        }
        .global-nav__controls a:hover { color: #f5f5f7; }
        .nav-bell {
            position: relative;
            font-size: 16px;
        }
        .nav-bell__badge {
            position: absolute;
            top: -6px;
            right: -8px;
            background: #fa3e3e;
            color: #fff;
            font-size: 9px;
            font-weight: 700;
            border-radius: 10px;
            padding: 1px 4px;
            line-height: 1.4;
        }
        .nav-submit {
            color: rgba(245,245,247,.8);
            font-size: 12px;
            padding: 4px 10px;
            border: 1px solid rgba(245,245,247,.3);
            border-radius: 980px;
            transition: all .2s;
        }
        .nav-submit:hover {
            background: rgba(245,245,247,.1);
            color: #f5f5f7;
            border-color: rgba(245,245,247,.5);
        }

        /* ── Flash messages ── */
        .flash {
            padding: 10px 20px;
            font-size: 13px;
            text-align: center;
        }
        .flash--success { background: #d4f4dd; color: #1a7a34; }
        .flash--error   { background: #fde8e8; color: #c0392b; }

        /* ── Page wrapper ── */
        .page { min-height: calc(100vh - 88px - 120px); }

        /* ── Footer ── */
        footer {
            background: #f5f5f7;
            border-top: 1px solid #d2d2d7;
            padding: 32px 20px 20px;
            color: #6e6e73;
            font-size: 12px;
        }
        .footer__inner {
            max-width: 1024px;
            margin: 0 auto;
        }
        .footer__tagline {
            font-size: 12px;
            color: #6e6e73;
            margin-bottom: 16px;
            padding-bottom: 16px;
            border-bottom: 1px solid #d2d2d7;
        }
        .footer__links {
            display: flex;
            flex-wrap: wrap;
            gap: 8px 20px;
        }
        .footer__links a {
            color: #6e6e73;
            font-size: 12px;
            transition: color .15s;
        }
        .footer__links a:hover { color: #1d1d1f; }
        .footer__copy {
            margin-top: 16px;
            color: #6e6e73;
            font-size: 12px;
        }

        /* ── Hero section (home) ── */
        .hero {
            text-align: center;
            padding: 80px 24px 64px;
            background: #fff;
        }
        .hero__eyebrow {
            font-size: 17px;
            font-weight: 400;
            color: #6e6e73;
            margin-bottom: 6px;
            letter-spacing: -.022em;
        }
        .hero__title {
            font-size: clamp(40px, 6vw, 64px);
            font-weight: 700;
            letter-spacing: -.005em;
            line-height: 1.06;
            color: #1d1d1f;
            margin-bottom: 12px;
        }
        .hero__sub {
            font-size: 19px;
            font-weight: 400;
            color: #6e6e73;
            letter-spacing: -.022em;
            max-width: 600px;
            margin: 0 auto 24px;
        }
        .hero__links { display: flex; gap: 24px; justify-content: center; align-items: center; }
        .hero__links a {
            font-size: 17px;
            color: #0071e3;
            letter-spacing: -.022em;
        }
        .hero__links a:hover { text-decoration: underline; }
        .hero__links a.secondary { color: #6e6e73; font-size: 14px; }
        .hero__image {
            max-width: 560px;
            width: 100%;
            margin: 40px auto 0;
            display: block;
            border-radius: 12px;
        }
        .hero__empty {
            padding: 120px 24px;
            text-align: center;
            color: #6e6e73;
            font-size: 17px;
        }

        /* ── Browse grid ── */
        .browse-header {
            padding: 48px 24px 24px;
            text-align: center;
            border-bottom: 1px solid #d2d2d7;
        }
        .browse-header h1 {
            font-size: 40px;
            font-weight: 700;
            letter-spacing: -.005em;
            color: #1d1d1f;
        }
        .product-grid {
            max-width: 1024px;
            margin: 0 auto;
            padding: 32px 24px;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 2px;
        }
        .product-card {
            background: #fbfbfd;
            padding: 32px 24px;
            text-align: center;
            transition: background .2s;
            border-radius: 2px;
        }
        .product-card:hover { background: #f5f5f7; }
        .product-card__type {
            font-size: 12px;
            color: #6e6e73;
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 8px;
        }
        .product-card__name {
            font-size: 21px;
            font-weight: 600;
            letter-spacing: -.025em;
            color: #1d1d1f;
            margin-bottom: 6px;
        }
        .product-card__year {
            font-size: 13px;
            color: #6e6e73;
            margin-bottom: 16px;
        }
        .product-card__link {
            font-size: 14px;
            color: #0071e3;
        }
        .product-card__link:hover { text-decoration: underline; }
        .browse-empty {
            text-align: center;
            padding: 80px 24px;
            color: #6e6e73;
            font-size: 17px;
        }

        /* ── Generic content page ── */
        .content-page {
            max-width: 860px;
            margin: 0 auto;
            padding: 48px 24px;
        }
        .content-page h1 {
            font-size: 36px;
            font-weight: 700;
            letter-spacing: -.005em;
            margin-bottom: 8px;
        }
        .content-page h2 {
            font-size: 24px;
            font-weight: 600;
            letter-spacing: -.025em;
            margin: 32px 0 12px;
            color: #1d1d1f;
        }
        .content-page table {
            width: 100%;
            border-collapse: collapse;
            margin: 16px 0;
            font-size: 14px;
        }
        .content-page table th {
            text-align: left;
            padding: 10px 14px;
            background: #f5f5f7;
            color: #6e6e73;
            font-weight: 500;
            border-bottom: 1px solid #d2d2d7;
            white-space: nowrap;
            width: 180px;
        }
        .content-page table td {
            padding: 10px 14px;
            border-bottom: 1px solid #f0f0f0;
            color: #1d1d1f;
        }
        .content-page p { margin: 8px 0; color: #6e6e73; }
        .content-page .back-link {
            display: inline-block;
            margin-top: 24px;
            font-size: 14px;
            color: #0071e3;
        }
        .content-page .back-link:hover { text-decoration: underline; }

        /* ── Buttons & forms ── */
        .btn {
            display: inline-block;
            padding: 8px 18px;
            border-radius: 980px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            transition: all .2s;
        }
        .btn-primary { background: #0071e3; color: #fff; }
        .btn-primary:hover { background: #0077ed; }
        .btn-danger { background: #fa3e3e; color: #fff; }
        .btn-danger:hover { background: #e03030; }
        .btn-secondary { background: transparent; color: #0071e3; border: 1px solid #0071e3; }
        .btn-secondary:hover { background: #0071e3; color: #fff; }

        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 13px; color: #6e6e73; margin-bottom: 4px; }
        .form-group input[type=text],
        .form-group input[type=date],
        .form-group input[type=number],
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 9px 12px;
            border: 1px solid #d2d2d7;
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            color: #1d1d1f;
            background: #fff;
            outline: none;
            transition: border-color .2s;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus { border-color: #0071e3; }
        .form-group textarea { resize: vertical; min-height: 80px; }

        /* ── Barista action bar ── */
        .action-bar {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            flex-wrap: wrap;
            margin-top: 24px;
            padding-top: 24px;
            border-top: 1px solid #d2d2d7;
        }
    </style>

    {% block stylesheets %}{% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body>

{# ── Global top bar ── #}
<div class="global-nav">
    <div class="global-nav__inner">
        <a class="global-nav__logo" href="{{ path('app_home') }}" title="Apple Time Machine">&#63743;</a>

        <div class="global-nav__controls">
            {% if is_granted('ROLE_USER') %}
                <a class="nav-submit" href="{{ path('app_product_new') }}">+ Submit</a>
            {% endif %}
            {% if is_granted('ROLE_REVIEWER') %}
                <a href="{{ path('app_review_index') }}" class="nav-bell" title="Pending reviews">
                    🔔
                    {% if pending_count > 0 %}
                        <span class="nav-bell__badge">{{ pending_count }}</span>
                    {% endif %}
                </a>
            {% endif %}
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_mydrilla') }}">Account</a>
            {% else %}
                <a href="{{ path('app_login') }}">Sign in</a>
                <a href="{{ path('app_register') }}">Create account</a>
            {% endif %}
        </div>
    </div>
</div>

{# ── Category store nav ── #}
<div class="store-nav">
    <div class="store-nav__inner">
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'iphone'}) }}">iPhone</a>
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'mac'}) }}">Mac</a>
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'ipad'}) }}">iPad</a>
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'watch'}) }}">Watch</a>
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'tv'}) }}">TV</a>
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'accessories'}) }}">Accessories</a>
        <a class="store-nav__item" href="{{ path('app_browse', {category: 'other'}) }}">Other</a>
    </div>
</div>

{# ── Flash messages ── #}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="flash flash--{{ label == 'error' ? 'error' : 'success' }}">{{ message }}</div>
    {% endfor %}
{% endfor %}

<div class="page">
    {% block body %}{% endblock %}
</div>

{# ── Footer ── #}
<footer>
    <div class="footer__inner">
        <p class="footer__tagline">
            Apple Time Machine — rediscovering the products that defined an era.
        </p>
        <div class="footer__links">
            <a href="{{ path('app_home') }}">Home</a>
            <a href="{{ path('app_browse', {category: 'iphone'}) }}">iPhone</a>
            <a href="{{ path('app_browse', {category: 'mac'}) }}">Mac</a>
            <a href="{{ path('app_browse', {category: 'ipad'}) }}">iPad</a>
            <a href="{{ path('app_browse', {category: 'watch'}) }}">Watch</a>
            <a href="{{ path('app_browse', {category: 'tv'}) }}">TV</a>
            <a href="{{ path('app_browse', {category: 'accessories'}) }}">Accessories</a>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_product_new') }}">Submit a product</a>
            {% else %}
                <a href="{{ path('app_register') }}">Create account</a>
            {% endif %}
        </div>
        <p class="footer__copy">
            Made with nostalgia and a deep appreciation for hardware that had a soul.<br>
            Copyright &copy; {{ "now"|date("Y") }} Apple Time Machine. Not affiliated with Apple Inc.
        </p>
    </div>
</footer>

</body>
</html>
