{% extends 'base.html.twig' %}
{% block title %}History — {{ product.productName }}{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-6 py-12">
    <p class="text-[10px] text-apple-gray uppercase tracking-widest mb-1">Modification history</p>
    <h1 class="text-4xl font-bold tracking-tight text-apple-dark mb-8">{{ product.productName }}</h1>

    {% if entries is empty %}
        <p class="text-apple-gray text-sm">No history recorded yet.</p>
    {% else %}
        <div class="border border-apple-border rounded-xl overflow-hidden">
            <table class="w-full text-sm">
                <thead class="bg-apple-light text-apple-gray text-xs uppercase tracking-widest">
                    <tr>
                        <th class="text-left px-5 py-3">Date</th>
                        <th class="text-left px-5 py-3">User</th>
                        <th class="text-left px-5 py-3">Action</th>
                        <th class="text-left px-5 py-3">Comment</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-apple-border">
                    {% for entry in entries %}
                        <tr class="hover:bg-apple-light transition-colors">
                            <td class="px-5 py-3 text-apple-gray whitespace-nowrap">{{ entry.date|date('Y-m-d H:i') }}</td>
                            <td class="px-5 py-3 font-mono text-xs text-apple-gray">{{ entry.user.userIdentifier|slice(0,8) }}…</td>
                            <td class="px-5 py-3 text-apple-dark font-medium">{{ entry.action.label() }}</td>
                            <td class="px-5 py-3 text-apple-gray">{{ entry.comment ?? '—' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}

    <a href="{{ path('app_product_show', {id: product.id}) }}"
       class="inline-block mt-8 text-sm text-apple-blue hover:underline">← Back to product</a>
</div>
{% endblock %}
